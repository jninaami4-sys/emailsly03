# ============================================================
# Emailsly frontend environment
# Copy to `.env.local` (dev) or `.env.production` (build) and edit.
# ============================================================

# Base URL of your PHP API (no trailing slash).
# Leave empty to call the API on the same origin as the SPA (e.g. cPanel
# hosting where the React build and /api PHP live under the same domain).
#
# Examples:
#   VITE_API_BASE_URL="https://api.emailsly.com"
#   VITE_API_BASE_URL="https://emailsly.com.bd/api"
#   VITE_API_BASE_URL=""            # same-origin, resolves to "/api/..."
VITE_API_BASE_URL=""

# ------------------------------------------------------------
# Runtime override (no rebuild required)
# ------------------------------------------------------------
# Instead of baking the URL at build time, you can inject it at page load
# by adding ONE of the following to `index.html` before the app script:
#
#   <script>window.__API_BASE__ = "https://api.emailsly.com";</script>
#   <meta name="api-base" content="https://api.emailsly.com">
#
# This is the recommended approach for the Bangladeshi cPanel deploy:
# upload the same build once, then edit index.html on the server to point
# at whichever PHP host you use.
