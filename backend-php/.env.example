# ============================================================
# Emailsly PHP API — environment configuration
# Copy this file to ".env" (same folder as this file) and fill
# in real values. Never commit the real .env to git or FTP a
# copy outside the backend folder.
# ============================================================

# --- App ---
APP_ENV=production                 # production | staging | local
APP_URL=https://emailsly.com       # public website URL (used for Stripe redirects, emails)
API_URL=https://api.emailsly.com   # public API URL (where this backend is served from)

# --- Database (MySQL 8.x, from cPanel > MySQL Databases) ---
# In cPanel the username/database are automatically prefixed with your
# account name, e.g. "emailsly_prod" and "emailsly_user".
DB_HOST=localhost
DB_PORT=3306
DB_NAME=emailsly_prod
DB_USER=emailsly_user
DB_PASS=change-me

# --- JWT signing ---
# Generate a strong random value once and keep it stable — rotating this
# secret invalidates every existing user session.
#   openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_TTL_DAYS=7

# --- Stripe ---
# Test keys (sk_test_..., whsec_...) while developing; live keys after
# you flip the domain live. The webhook secret comes from the Stripe
# dashboard > Developers > Webhooks > "Signing secret".
STRIPE_SECRET_KEY=sk_test_demo_replace_me_1234567890abcdefghijklmnopqrstuvwxyz
STRIPE_WEBHOOK_SECRET=whsec_demo_replace_me_1234567890abcdefghijklmnopqrstuvwxyz
STRIPE_WEBHOOK_TOLERANCE=300

# --- Outbound email (cPanel > Email Accounts) ---
# Two sender identities, both authenticated via your cPanel SMTP server.
# Auth channel  -> password resets, email verification, magic links
# Orders channel-> order confirmations to customer + admin copy
SMTP_HOST=mail.emailsly.com
SMTP_PORT=587
SMTP_SECURE=tls                    # tls (STARTTLS on 587) | ssl (465) | none

# Auth sender (no-reply@mail.emailsly.com)
SMTP_AUTH_USER=no-reply@mail.emailsly.com
SMTP_AUTH_PASS=
SMTP_AUTH_FROM=no-reply@mail.emailsly.com
SMTP_AUTH_FROM_NAME=Emailsly Security

# Orders sender (orders@mail.emailsly.com)
SMTP_ORDERS_USER=orders@mail.emailsly.com
SMTP_ORDERS_PASS=
SMTP_ORDERS_FROM=orders@mail.emailsly.com
SMTP_ORDERS_FROM_NAME=Emailsly Orders

# Where an internal copy of every new order is delivered
ORDERS_ADMIN_INBOX=orders@mail.emailsly.com

# Support sender (support@mail.emailsly.com) — ticket notifications & replies
SMTP_SUPPORT_USER=support@mail.emailsly.com
SMTP_SUPPORT_PASS=
SMTP_SUPPORT_FROM=support@mail.emailsly.com
SMTP_SUPPORT_FROM_NAME=Emailsly Support
SUPPORT_ADMIN_INBOX=support@mail.emailsly.com

# Contact sender (hello@emailsly.com) — contact-form auto-reply & internal copy
SMTP_CONTACT_USER=hello@emailsly.com
SMTP_CONTACT_PASS=
SMTP_CONTACT_FROM=hello@emailsly.com
SMTP_CONTACT_FROM_NAME=Emailsly
CONTACT_ADMIN_INBOX=hello@emailsly.com

# --- Admin ---
# Email that first receives the seeded admin role. Must match the
# email you sign the first admin user up with.
ADMIN_EMAIL=admin@emailsly.com

# --- CORS ---
# Comma-separated list of origins that may call the API from a browser.
# Include every domain the frontend runs on (production, staging, and
# your local Vite dev server). No trailing slash.
CORS_ORIGINS=https://emailsly.com,https://www.emailsly.com,http://localhost:5173

# --- File uploads ---
# Absolute cap in bytes for a single upload (default 10 MB). Must be
# <= the smaller of php.ini `upload_max_filesize` and `post_max_size`.
UPLOAD_MAX_BYTES=10485760

# Absolute filesystem path where uploads are written. Recommend a folder
# under public_html so Apache can serve them directly without PHP.
#   e.g. /home/emailsly/public_html/uploads
UPLOADS_DIR=/home/emailsly/public_html/uploads

# Public URL prefix for that same folder. Must match UPLOADS_DIR.
UPLOADS_PUBLIC_URL=https://emailsly.com/uploads