# Copy to .env and fill in
APP_ENV=production
APP_URL=https://emailsly.com
API_URL=https://api.emailsly.com

DB_HOST=localhost
DB_PORT=3306
DB_NAME=emailsly_prod
DB_USER=emailsly_user
DB_PASS=change-me

JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_TTL_DAYS=7

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SMTP_HOST=mail.emailsly.com
SMTP_PORT=587
SMTP_USER=noreply@emailsly.com
SMTP_PASS=
SMTP_FROM=noreply@emailsly.com

ADMIN_EMAIL=admin@emailsly.com

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://emailsly.com,https://www.emailsly.com,http://localhost:5173
